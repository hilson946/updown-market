# Copy to .env.deploy. Never commit .env.deploy or private keys.

# base-sepolia or base-mainnet
NETWORK=base-sepolia

# Use a dedicated paid/private RPC for production. Public Base RPCs are rate-limited.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Hot deployer only for testnet. Use hardware/multisig operational controls for mainnet.
DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_DEPLOYER_KEY

# Mainnet examples:
# WETH on Base: 0x4200000000000000000000000000000000000006
# Native USDC on Base: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
COLLATERAL_ADDRESS=0xREPLACE_WITH_USDC
BASE_TOKEN=0x4200000000000000000000000000000000000006
QUOTE_TOKEN=0xREPLACE_WITH_USDC

# Comma-separated Uniswap v3 pool addresses for the same base/quote pair, max 5.
# Prefer multiple deep pools and verify with Uniswap Info or factory.getPool(tokenA, tokenB, fee).
POOL_ADDRESSES=0xREPLACE_WITH_POOL_1,0xREPLACE_WITH_POOL_2

FEE_VAULT=0xREPLACE_WITH_FEE_VAULT
FRONTEND_PAYOUT=0xREPLACE_WITH_FRONTEND_PAYOUT
FRONTEND_ID=1
FEE_BPS=50
TWAP_WINDOW_SECONDS=60
MIN_POOL_LIQUIDITY=1
# Delay before the betting window opens. predictionStart is computed as now + duration + this delay.
TRADING_START_DELAY_SECONDS=900
MARKET_DURATIONS=5m,1h,1d
